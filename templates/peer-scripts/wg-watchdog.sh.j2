#!/usr/bin/env bash
# WireGuard watchdog — generated by wgmesh for peer {{ peer.name }}
# Checks hub reachability; re-resolves DNS; restarts WireGuard if needed.
# Install via: wgmesh gen-peer-scripts {{ peer.name }}

set -euo pipefail

HUB_IP="10.100.0.1"
HUB_ENDPOINT="{{ hub_endpoint_host }}"
HUB_PUBKEY="{{ hub.public_key }}"
WG_IFACE="wg0"
FAIL_THRESHOLD=3
COUNTER_FILE="/run/wg-watchdog-failures"
LOG_TAG="wg-watchdog"

log() { logger -t "$LOG_TAG" "$*"; }

# Initialise failure counter
failures=$(cat "$COUNTER_FILE" 2>/dev/null || echo 0)

# Step 1: Re-resolve DNS and update WireGuard endpoint if changed
resolved_ip=$(dig +short "$HUB_ENDPOINT" A 2>/dev/null | tail -1)
if [[ -n "$resolved_ip" ]]; then
    current_ep=$(wg show "$WG_IFACE" endpoints 2>/dev/null | grep "$HUB_PUBKEY" | awk '{print $2}' || true)
    current_ip=$(echo "$current_ep" | cut -d: -f1)
    if [[ "$resolved_ip" != "$current_ip" ]]; then
        log "DNS changed: $current_ip -> $resolved_ip — updating endpoint"
        wg set "$WG_IFACE" peer "$HUB_PUBKEY" endpoint "${resolved_ip}:51820"
    fi
fi

# Step 2: Ping hub WireGuard IP
if ping -c 1 -W 3 "$HUB_IP" >/dev/null 2>&1; then
    if [[ "$failures" -gt 0 ]]; then
        log "Hub reachable (was failing for $failures checks)"
    fi
    echo 0 > "$COUNTER_FILE"
    exit 0
fi

# Step 3: Ping failed — increment counter
failures=$((failures + 1))
echo "$failures" > "$COUNTER_FILE"
log "Ping failed ($failures/$FAIL_THRESHOLD)"

if [[ "$failures" -ge "$FAIL_THRESHOLD" ]]; then
    log "Threshold reached — restarting WireGuard"
    if command -v systemctl >/dev/null 2>&1; then
        systemctl restart "wg-quick@${WG_IFACE}"
    elif command -v wg-quick >/dev/null 2>&1; then
        wg-quick down "$WG_IFACE" 2>/dev/null || true
        wg-quick up "$WG_IFACE"
    fi
    echo 0 > "$COUNTER_FILE"
fi
