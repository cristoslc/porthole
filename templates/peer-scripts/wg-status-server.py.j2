#!/usr/bin/env python3
"""WireGuard status web server for {{ peer.name }}.
Serves tunnel health info on port 8888 (LAN-only, no auth).
Generated by wgmesh gen-peer-scripts.
"""
import html
import subprocess
import sys
from datetime import datetime, timezone
from http.server import BaseHTTPRequestHandler, HTTPServer

PEER_NAME = "{{ peer.name }}"
PEER_IP   = "{{ peer.ip }}"
PEER_DNS  = "{{ peer.name }}.{{ peer.name.split('.')[0] if '.' in peer.name else 'wg' }}"
WG_IFACE  = "wg0"
PORT      = 8888

# --------------------------------------------------------------------------- #
# WireGuard data                                                               #
# --------------------------------------------------------------------------- #

def _wg_show():
    """Return parsed `wg show wg0 dump` output as a dict, or None on error."""
    try:
        out = subprocess.check_output(
            ["sudo", "wg", "show", WG_IFACE, "dump"],
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None

    lines = out.strip().splitlines()
    if not lines:
        return None

    # First line is the interface line:
    # private-key  public-key  listen-port  fwmark
    iface_fields = lines[0].split("\t")
    iface = {
        "public_key": iface_fields[1] if len(iface_fields) > 1 else "(unknown)",
        "listen_port": iface_fields[2] if len(iface_fields) > 2 else "(unknown)",
    }

    # Remaining lines are peer lines:
    # public-key  preshared-key  endpoint  allowed-ips  latest-handshake  rx  tx  keepalive
    peers = []
    for line in lines[1:]:
        f = line.split("\t")
        if len(f) < 8:
            continue
        handshake_ts = int(f[4]) if f[4].isdigit() else 0
        if handshake_ts:
            age_s = int(datetime.now(timezone.utc).timestamp()) - handshake_ts
            if age_s < 60:
                handshake_str = f"{age_s}s ago"
            elif age_s < 3600:
                handshake_str = f"{age_s // 60}m ago"
            else:
                handshake_str = f"{age_s // 3600}h {(age_s % 3600) // 60}m ago"
        else:
            handshake_str = "never"
        peers.append({
            "public_key": f[0][:16] + "...",
            "endpoint":   f[2] if f[2] != "(none)" else "—",
            "allowed_ips": f[3],
            "handshake":  handshake_str,
            "rx_bytes":   _fmt_bytes(int(f[5]) if f[5].isdigit() else 0),
            "tx_bytes":   _fmt_bytes(int(f[6]) if f[6].isdigit() else 0),
        })
    return {"iface": iface, "peers": peers}


def _fmt_bytes(n):
    for unit in ("B", "KiB", "MiB", "GiB"):
        if n < 1024:
            return f"{n:.1f} {unit}"
        n /= 1024
    return f"{n:.1f} TiB"


def _wg_up():
    """Return True if the WireGuard interface appears to be up."""
    try:
        subprocess.check_call(
            ["ip", "link", "show", WG_IFACE],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
        return True
    except (subprocess.CalledProcessError, FileNotFoundError):
        return False


# --------------------------------------------------------------------------- #
# HTML rendering                                                               #
# --------------------------------------------------------------------------- #

_STYLE = """
body { font-family: system-ui, sans-serif; max-width: 760px; margin: 2rem auto; padding: 0 1rem; color: #222; }
h1   { font-size: 1.4rem; margin-bottom: 0.25rem; }
.sub { color: #666; font-size: 0.9rem; margin-bottom: 1.5rem; }
.badge-up   { background: #22c55e; color: #fff; padding: 0.2em 0.6em; border-radius: 4px; font-size: 0.85rem; }
.badge-down { background: #ef4444; color: #fff; padding: 0.2em 0.6em; border-radius: 4px; font-size: 0.85rem; }
table  { width: 100%; border-collapse: collapse; margin: 1rem 0; }
th, td { text-align: left; padding: 0.4rem 0.6rem; border-bottom: 1px solid #e5e5e5; font-size: 0.9rem; }
th     { background: #f5f5f5; font-weight: 600; }
button { background: #3b82f6; color: #fff; border: none; padding: 0.5rem 1.2rem;
         border-radius: 6px; cursor: pointer; font-size: 0.95rem; margin-top: 1rem; }
button:hover { background: #2563eb; }
.ok   { color: #16a34a; }
.warn { color: #d97706; }
"""

def _render_page(wg):
    up = wg is not None and wg["peers"]
    badge = '<span class="badge-up">UP</span>' if up else '<span class="badge-down">DOWN</span>'

    peer_rows = ""
    if wg:
        for p in wg["peers"]:
            hs_class = "ok" if "ago" in p["handshake"] and int(p["handshake"].split("m")[0].split("h")[0].replace("s","").strip()) < 5 else "warn"
            peer_rows += f"""
            <tr>
              <td style="font-family:monospace;font-size:0.8rem">{html.escape(p['public_key'])}</td>
              <td>{html.escape(p['endpoint'])}</td>
              <td>{html.escape(p['allowed_ips'])}</td>
              <td class="{hs_class}">{html.escape(p['handshake'])}</td>
              <td>{html.escape(p['rx_bytes'])}</td>
              <td>{html.escape(p['tx_bytes'])}</td>
            </tr>"""

    peer_table = f"""
    <table>
      <thead><tr>
        <th>Public Key</th><th>Endpoint</th><th>Allowed IPs</th>
        <th>Last Handshake</th><th>Rx</th><th>Tx</th>
      </tr></thead>
      <tbody>{peer_rows if peer_rows else '<tr><td colspan="6">No peers</td></tr>'}</tbody>
    </table>""" if wg else "<p>Could not read WireGuard status (wg not found or interface down).</p>"

    now = datetime.now().strftime("%H:%M:%S")
    return f"""<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta http-equiv="refresh" content="30">
  <title>wgmesh — {html.escape(PEER_NAME)}</title>
  <style>{_STYLE}</style>
</head>
<body>
  <h1>wgmesh node: {html.escape(PEER_NAME)} {badge}</h1>
  <p class="sub">
    WireGuard IP: <strong>{html.escape(PEER_IP)}</strong> &nbsp;|&nbsp;
    DNS: <strong>{html.escape(PEER_DNS)}</strong> &nbsp;|&nbsp;
    Updated: {now} (auto-refresh 30 s)
  </p>
  {peer_table}
  <form method="post" action="/restart"
        onsubmit="return confirm('Restart WireGuard tunnel?')">
    <button type="submit">Restart Tunnel</button>
  </form>
</body>
</html>
"""


def _render_restart_result(success, message):
    colour = "#22c55e" if success else "#ef4444"
    return f"""<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="refresh" content="3;url=/">
  <title>Restarting tunnel…</title>
  <style>body{{font-family:system-ui,sans-serif;max-width:600px;margin:3rem auto;padding:0 1rem}}</style>
</head>
<body>
  <h2 style="color:{colour}">{"Success" if success else "Error"}</h2>
  <p>{html.escape(message)}</p>
  <p><small>Redirecting back in 3 s…</small></p>
</body>
</html>
"""


# --------------------------------------------------------------------------- #
# HTTP handler                                                                 #
# --------------------------------------------------------------------------- #

class StatusHandler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):  # silence default access log
        pass

    def _send_html(self, code, body):
        data = body.encode()
        self.send_response(code)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self):
        if self.path not in ("/", "/favicon.ico"):
            self._send_html(404, "<h1>404 Not Found</h1>")
            return
        if self.path == "/favicon.ico":
            self.send_response(204)
            self.end_headers()
            return
        wg = _wg_show()
        self._send_html(200, _render_page(wg))

    def do_POST(self):
        if self.path != "/restart":
            self._send_html(404, "<h1>404 Not Found</h1>")
            return
        # Consume body
        length = int(self.headers.get("Content-Length", 0))
        self.rfile.read(length)
        # Attempt restart
        try:
            subprocess.run(
                ["sudo", "systemctl", "restart", "wg-quick@wg0"],
                check=True, capture_output=True, text=True,
            )
            self._send_html(200, _render_restart_result(True, "WireGuard tunnel restarted successfully."))
        except subprocess.CalledProcessError as e:
            self._send_html(200, _render_restart_result(False, f"Restart failed: {e.stderr or str(e)}"))
        except FileNotFoundError:
            self._send_html(200, _render_restart_result(False, "systemctl not found (macOS?). Run: sudo launchctl kickstart -k system/com.wireguard.wg0"))


# --------------------------------------------------------------------------- #
# Entry point                                                                  #
# --------------------------------------------------------------------------- #

if __name__ == "__main__":
    server = HTTPServer(("0.0.0.0", PORT), StatusHandler)
    print(f"wgmesh status server for {PEER_NAME} listening on http://0.0.0.0:{PORT}/", flush=True)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        sys.exit(0)
