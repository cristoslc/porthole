# WireGuard watchdog — generated by porthole for peer {{ peer.name }}
# Checks hub reachability; re-resolves DNS; restarts WireGuard if needed.
# Install via Task Scheduler (see wg-watchdog-task.xml).
#
# Requires WireGuard for Windows installed. The tunnel must be set up and
# the WireGuard service must be running as WireGuardTunnel$wg0.
#
# Run with: PowerShell -NonInteractive -File wg-watchdog.ps1
# Must be run as Administrator (Task Scheduler runs as SYSTEM by default).

$HUB_WG_IP     = "{{ hub.ip }}"
$HUB_ENDPOINT  = "{{ hub_endpoint_host }}"
$HUB_PUBKEY    = "{{ hub.public_key }}"
$WG_IFACE      = "wg0"
$WG_SERVICE    = "WireGuardTunnel`$$WG_IFACE"
$FAIL_THRESHOLD = 3
$COUNTER_FILE  = "$env:TEMP\wg-watchdog-failures-{{ peer.name }}.txt"
$LOG_SOURCE    = "Porthole"
$LOG_NAME      = "Application"

function Write-Log {
    param([string]$Message)
    $timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
    $line = "[$timestamp] [wg-watchdog] $Message"
    Write-Host $line
    # Write to Windows Event Log if the source exists; otherwise fall back to file log.
    try {
        if (-not [System.Diagnostics.EventLog]::SourceExists($LOG_SOURCE)) {
            New-EventLog -LogName $LOG_NAME -Source $LOG_SOURCE -ErrorAction SilentlyContinue
        }
        Write-EventLog -LogName $LOG_NAME -Source $LOG_SOURCE -EntryType Information `
            -EventId 1000 -Message $Message -ErrorAction SilentlyContinue
    } catch { }
}

# --- Load failure counter ---
$failures = 0
if (Test-Path $COUNTER_FILE) {
    $raw = Get-Content $COUNTER_FILE -ErrorAction SilentlyContinue
    if ($raw -match '^\d+$') { $failures = [int]$raw }
}

# --- Step 1: Re-resolve DNS and update endpoint if changed ---
try {
    $resolved = [System.Net.Dns]::GetHostAddresses($HUB_ENDPOINT) |
        Where-Object { $_.AddressFamily -eq 'InterNetwork' } |
        Select-Object -First 1 -ExpandProperty IPAddressToString

    if ($resolved) {
        # Get the current endpoint from `wg show`
        $wgShow = & wg show $WG_IFACE endpoints 2>$null
        if ($wgShow) {
            $currentLine = $wgShow -split "`n" | Where-Object { $_ -match $HUB_PUBKEY }
            if ($currentLine -match '(\d+\.\d+\.\d+\.\d+):') {
                $currentIp = $Matches[1]
                if ($currentIp -ne $resolved) {
                    Write-Log "DNS changed: $currentIp -> $resolved — updating endpoint"
                    & wg set $WG_IFACE peer $HUB_PUBKEY endpoint "${resolved}:51820" 2>$null
                }
            }
        }
    }
} catch {
    Write-Log "DNS re-resolve failed: $_"
}

# --- Step 2: Ping hub WireGuard IP ---
$pingOk = Test-Connection -ComputerName $HUB_WG_IP -Count 1 -Quiet -ErrorAction SilentlyContinue

if ($pingOk) {
    if ($failures -gt 0) {
        Write-Log "Hub reachable (was failing for $failures checks)"
    }
    Set-Content -Path $COUNTER_FILE -Value "0"
    exit 0
}

# --- Step 3: Ping failed — increment counter ---
$failures++
Set-Content -Path $COUNTER_FILE -Value "$failures"
Write-Log "Ping failed ($failures/$FAIL_THRESHOLD)"

if ($failures -ge $FAIL_THRESHOLD) {
    Write-Log "Threshold reached — restarting WireGuard service $WG_SERVICE"
    try {
        Restart-Service -Name $WG_SERVICE -Force -ErrorAction Stop
        Write-Log "WireGuard service restarted successfully"
    } catch {
        Write-Log "Failed to restart WireGuard service: $_"
        # Fallback: try via wireguard.exe if service restart fails
        try {
            & wireguard.exe /uninstalltunnel $WG_IFACE 2>$null
            Start-Sleep -Seconds 2
            & wireguard.exe /installtunnel "$env:WG_CONF_DIR\$WG_IFACE.conf" 2>$null
            Write-Log "Fallback tunnel reinstall attempted"
        } catch {
            Write-Log "Fallback reinstall also failed: $_"
        }
    }
    Set-Content -Path $COUNTER_FILE -Value "0"
}
