-- Guacamole connection seed — generated from network.sops.yaml
-- Run after Guacamole schema has been applied (01-schema.sql).
-- Re-running is safe: uses INSERT ... ON CONFLICT DO NOTHING.

{% for peer in peers %}
{% if peer.role in ("workstation", "family", "server") %}
-- {{ peer.name }} ({{ peer.role }}, {{ peer.ip }})
{% if peer.role == "server" %}
-- SSH only
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-ssh', 'ssh')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter
  (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES
       ('hostname', '{{ peer.ip }}'),
       ('port', '22')
     ) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-ssh'
ON CONFLICT DO NOTHING;

{% elif peer.os_hint == "windows" %}
-- RDP
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-rdp', 'rdp')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter
  (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES
       ('hostname', '{{ peer.ip }}'),
       ('port', '3389'),
       ('security', 'nla'),
       ('ignore-cert', 'true')
     ) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-rdp'
ON CONFLICT DO NOTHING;

{% elif peer.os_hint == "macos" %}
-- VNC (Screen Sharing)
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-vnc', 'vnc')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter
  (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES
       ('hostname', '{{ peer.ip }}'),
       ('port', '5900')
     ) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-vnc'
ON CONFLICT DO NOTHING;

{% else %}
-- xrdp (Linux default)
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-rdp', 'rdp')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter
  (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES
       ('hostname', '{{ peer.ip }}'),
       ('port', '3389'),
       ('security', 'any'),
       ('ignore-cert', 'true')
     ) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-rdp'
ON CONFLICT DO NOTHING;

{% endif %}
-- SSH for all non-hub peers
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-ssh', 'ssh')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter
  (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES
       ('hostname', '{{ peer.ip }}'),
       ('port', '22')
     ) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-ssh'
ON CONFLICT DO NOTHING;

{% endif %}
{% endfor %}
