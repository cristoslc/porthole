-- Guacamole connection seed — generated by Ansible from network state.
-- Run after Guacamole schema has been applied (initdb.sh --postgresql).
-- Re-running is safe: uses INSERT ... ON CONFLICT DO NOTHING.
--
-- Protocol selection matches templates/guacamole-seed.sql.j2:
--   peer.role == "server"    → SSH only (regardless of platform)
--   peer.platform == "windows" → RDP + SSH
--   peer.platform == "macos"   → VNC (Screen Sharing) + SSH
--   peer.platform == "linux" or unset → xrdp (RDP) + SSH

{% for peer in spoke_peers %}
{% if peer.role in ['workstation', 'family', 'server'] %}
-- {{ peer.name }} (role={{ peer.role }}, platform={{ peer.platform | default('unset') }}, ip={{ peer.ip }})

{% if peer.role == 'server' %}
-- SSH only (server role)
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-ssh', 'ssh')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES ('hostname', '{{ peer.ip }}'), ('port', '22')) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-ssh'
ON CONFLICT DO NOTHING;

{% elif peer.platform == 'windows' %}
-- RDP (Windows)
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-rdp', 'rdp')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES
       ('hostname',    '{{ peer.ip }}'),
       ('port',        '3389'),
       ('security',    'nla'),
       ('ignore-cert', 'true')
     ) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-rdp'
ON CONFLICT DO NOTHING;

-- SSH (Windows)
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-ssh', 'ssh')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES ('hostname', '{{ peer.ip }}'), ('port', '22')) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-ssh'
ON CONFLICT DO NOTHING;

{% elif peer.platform == 'macos' %}
-- VNC / Screen Sharing (macOS)
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-vnc', 'vnc')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES ('hostname', '{{ peer.ip }}'), ('port', '5900')) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-vnc'
ON CONFLICT DO NOTHING;

-- SSH (macOS)
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-ssh', 'ssh')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES ('hostname', '{{ peer.ip }}'), ('port', '22')) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-ssh'
ON CONFLICT DO NOTHING;

{% else %}
-- xrdp / RDP (Linux or platform unset)
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-rdp', 'rdp')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES
       ('hostname',    '{{ peer.ip }}'),
       ('port',        '3389'),
       ('security',    'any'),
       ('ignore-cert', 'true')
     ) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-rdp'
ON CONFLICT DO NOTHING;

-- SSH (Linux)
INSERT INTO guacamole_connection (connection_name, protocol)
  VALUES ('{{ peer.name }}-ssh', 'ssh')
  ON CONFLICT DO NOTHING;
INSERT INTO guacamole_connection_parameter (connection_id, parameter_name, parameter_value)
SELECT c.connection_id, p.name, p.value
FROM guacamole_connection c,
     (VALUES ('hostname', '{{ peer.ip }}'), ('port', '22')) AS p(name, value)
WHERE c.connection_name = '{{ peer.name }}-ssh'
ON CONFLICT DO NOTHING;

{% endif %}
{% endif %}
{% endfor %}
