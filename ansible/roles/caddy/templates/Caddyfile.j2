# Caddyfile — generated by Ansible from network state.
# Do not edit manually.

{{ net.hub.endpoint }} {
    {% if caddy_email | default('') %}
    tls {{ caddy_email }}
    {% else %}
    tls internal
    {% endif %}

    # Guacamole reverse proxy (WireGuard-only listener)
    reverse_proxy {{ hub_peer.ip }}:8080

    log {
        output file /var/log/caddy/access.log
    }
}
